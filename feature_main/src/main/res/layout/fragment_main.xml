<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/main_screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/main_toolbar_margin_top"
            android:layout_marginStart="@dimen/main_screen_padding_horizontal"
            android:layout_marginEnd="@dimen/main_screen_padding_horizontal"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/searchContainer"
                android:layout_width="0dp"
                android:layout_height="@dimen/main_search_height"
                android:layout_weight="1"
                android:background="@drawable/bg_search_field"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/main_search_padding_horizontal"
                android:paddingEnd="@dimen/main_search_padding_horizontal">

                <ImageView
                    android:id="@+id/searchIcon"
                    android:layout_width="@dimen/main_search_icon_size"
                    android:layout_height="@dimen/main_search_icon_size"
                    android:contentDescription="@string/main_search_content_description"
                    android:src="@drawable/ic_search" />

                <EditText
                    android:id="@+id/searchEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/main_search_icon_margin_start"
                    android:minHeight="48dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="@android:color/transparent"
                    android:hint="@string/main_search_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:importantForAutofill="no"
                    android:textColor="@color/main_text_primary"
                    android:textColorHint="@color/main_search_hint"
                    android:textSize="@dimen/main_search_text_size"
                    tools:ignore="TextFields"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/filterButton"
                android:layout_width="@dimen/main_filter_button_size"
                android:layout_height="@dimen/main_filter_button_size"
                android:layout_marginStart="@dimen/main_filter_margin_start"
                android:contentDescription="@string/main_filter_content_description"
                android:src="@drawable/ic_filter_bttn" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sortContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/main_sort_margin_top"
            android:layout_marginEnd="@dimen/main_sort_margin_end"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/sortText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/main_sort_by_date"
                android:textColor="@color/main_accent_green"
                android:textSize="@dimen/main_sort_text_size" />

            <TextView
                android:id="@+id/sortArrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/main_sort_arrow_margin_start"
                android:text="@string/main_sort_arrow"
                android:textColor="@color/main_accent_green"
                android:textSize="@dimen/main_sort_arrow_text_size" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/coursesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="@dimen/main_list_margin_top"
            android:clipToPadding="false"
            android:paddingStart="@dimen/main_screen_padding_horizontal"
            android:paddingEnd="@dimen/main_screen_padding_horizontal"
            android:paddingBottom="@dimen/main_list_padding_bottom"
            android:importantForAccessibility="no"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/mainProgressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:indeterminateTint="@android:color/holo_blue_light"
        android:visibility="gone" />

</FrameLayout>
