<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="auth_text_title">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/auth_text_size_title</item>
        <item name="android:lineHeight">@dimen/auth_line_height_title</item>
        <item name="android:textColor">@color/auth_text_primary</item>
    </style>

    <style name="auth_text_registration_title">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/auth_text_size_registration_title</item>
        <item name="android:textColor">@color/auth_text_primary</item>
    </style>

    <style name="auth_text_label">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/auth_text_size_label</item>
        <item name="android:lineHeight">@dimen/auth_line_height_label</item>
        <item name="android:letterSpacing">0.009375</item>
        <item name="android:textColor">@color/auth_text_primary</item>
    </style>

    <style name="auth_text_bottom">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/auth_text_size_bottom</item>
        <item name="android:lineHeight">@dimen/auth_line_height_bottom</item>
        <item name="android:letterSpacing">0.0333333</item>
    </style>

    <style name="auth_button_primary">
        <item name="android:background">@drawable/bg_auth_login_button</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/auth_text_primary</item>
        <item name="android:textSize">@dimen/auth_text_size_button</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="auth_edit_text_small">
        <item name="android:background">@drawable/bg_auth_field</item>
        <item name="android:textColor">@color/auth_text_primary</item>
        <item name="android:textColorHint">@color/auth_text_primary</item>
        <item name="android:textSize">@dimen/auth_text_size_hint_small</item>
        <item name="android:paddingStart">@dimen/auth_field_padding_horizontal_small</item>
        <item name="android:paddingEnd">@dimen/auth_field_padding_horizontal_small</item>
    </style>

    <style name="auth_edit_text_large">
        <item name="android:background">@drawable/bg_auth_edit_text</item>
        <item name="android:textColor">@color/auth_text_primary</item>
        <item name="android:textColorHint">@color/auth_text_primary</item>
        <item name="android:textSize">@dimen/auth_text_size_hint_large</item>
        <item name="android:paddingStart">@dimen/auth_field_padding_horizontal_large</item>
        <item name="android:paddingEnd">@dimen/auth_field_padding_horizontal_large</item>
    </style>

</resources>