<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="@dimen/profile_progress_radius" />
            <solid android:color="@color/profile_progress_bg" />
        </shape>
    </item>

    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="@dimen/profile_progress_radius" />
                <solid android:color="@color/profile_green" />
            </shape>
        </clip>
    </item>
</layer-list>