<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="profile_text_title">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/profile_text_size_title</item>
        <item name="android:lineHeight">@dimen/profile_line_height_title</item>
        <item name="android:textColor">@color/profile_text_primary</item>
    </style>

    <style name="profile_text_menu_item">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/profile_text_size_menu_item</item>
        <item name="android:lineHeight">@dimen/profile_line_height_menu_item</item>
        <item name="android:textColor">@color/profile_text_primary</item>
    </style>

    <style name="profile_text_section_title">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/profile_text_size_title</item>
        <item name="android:lineHeight">@dimen/profile_line_height_title</item>
        <item name="android:textColor">@color/profile_text_primary</item>
    </style>

    <style name="profile_text_course_title">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/profile_text_size_course_title</item>
        <item name="android:lineHeight">@dimen/profile_line_height_course_title</item>
        <item name="android:letterSpacing">0.009375</item>
        <item name="android:textColor">@color/profile_text_primary</item>
    </style>

    <style name="profile_text_course_meta">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/profile_text_size_course_meta</item>
        <item name="android:lineHeight">@dimen/profile_line_height_course_meta</item>
        <item name="android:letterSpacing">0.0333333</item>
        <item name="android:textColor">@color/profile_text_primary</item>
    </style>

    <style name="profile_text_progress_left">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/profile_text_size_progress</item>
        <item name="android:lineHeight">@dimen/profile_line_height_progress</item>
        <item name="android:textColor">@color/profile_green</item>
    </style>

    <style name="profile_text_progress_right">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/profile_text_size_progress</item>
        <item name="android:lineHeight">@dimen/profile_line_height_progress</item>
        <item name="android:textColor">@color/profile_text_primary</item>
    </style>

</resources>