<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="course_text_title">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/course_text_size_title</item>
        <item name="android:lineHeight">@dimen/course_line_height_title</item>
        <item name="android:textColor">@color/course_text_primary</item>
    </style>

    <style name="course_text_meta">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/course_text_size_meta</item>
        <item name="android:lineHeight">@dimen/course_line_height_meta</item>
        <item name="android:letterSpacing">0.0333333</item>
        <item name="android:textColor">@color/course_text_primary</item>
    </style>

    <style name="course_text_author_label">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/course_text_size_meta</item>
        <item name="android:lineHeight">@dimen/course_line_height_author_label</item>
        <item name="android:letterSpacing">0.0333333</item>
        <item name="android:textColor">@color/course_text_primary</item>
    </style>

    <style name="course_text_author_name">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/course_text_size_author_name</item>
        <item name="android:lineHeight">@dimen/course_line_height_author_name</item>
        <item name="android:letterSpacing">0.009375</item>
        <item name="android:textColor">@color/course_text_primary</item>
    </style>

    <style name="course_text_button">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/course_text_size_button</item>
        <item name="android:lineHeight">@dimen/course_line_height_button</item>
        <item name="android:textColor">@color/course_text_primary</item>
    </style>

    <style name="course_text_section_title">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/course_text_size_title</item>
        <item name="android:lineHeight">@dimen/course_line_height_title</item>
        <item name="android:textColor">@color/course_text_primary</item>
    </style>

    <style name="course_text_body">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/course_text_size_body</item>
        <item name="android:lineHeight">@dimen/course_line_height_body</item>
        <item name="android:textColor">@color/course_text_primary</item>
    </style>

    <style name="course_button_primary">
        <item name="android:background">@drawable/bg_course_button_green</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/course_text_primary</item>
        <item name="android:textSize">@dimen/course_text_size_button</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="course_button_secondary">
        <item name="android:background">@drawable/bg_course_button_dark</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/course_text_primary</item>
        <item name="android:textSize">@dimen/course_text_size_button</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
    </style>

</resources>