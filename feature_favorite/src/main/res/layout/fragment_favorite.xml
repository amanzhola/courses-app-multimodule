<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/favorite_screen_background"
    android:orientation="vertical">

    <TextView
        android:id="@+id/favoriteTitleTextView"
        style="@style/favorite_text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/favorite_screen_padding_horizontal"
        android:layout_marginTop="@dimen/favorite_title_margin_top"
        android:text="@string/favorite_title" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/favoriteRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/favorite_list_margin_top"
        android:clipToPadding="false"
        android:paddingStart="@dimen/favorite_screen_padding_horizontal"
        android:paddingEnd="@dimen/favorite_screen_padding_horizontal"
        android:paddingBottom="@dimen/favorite_list_padding_bottom"
        android:importantForAccessibility="no"/>

</LinearLayout>